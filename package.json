{
  "name": "fga-mcp",
  "version": "1.0.1",
  "description": "MCP Server for OpenFGA or Auth0 FGA",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fga-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "prepublishOnly": "npm run test:unit",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "docs:sync": "tsx tools/documentation-sync/sync.ts",
    "test": "npm run test:unit",
    "test:unit": "vitest run --config vitest.config.ts --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts --coverage",
    "test:integration:docker": "docker compose -f docker-compose.test.yml up --build --abort-on-container-exit --exit-code-from test-runner"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BobDickinson/fga-mcp.git"
  },
  "keywords": ["openfga", "mcp", "authorization", "fga"],
  "author": "Bob Dickinson",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/BobDickinson/fga-mcp/issues"
  },
  "homepage": "https://github.com/BobDickinson/fga-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openfga/sdk": "^0.9.6",
    "@openfga/syntax-transformer": "^0.2.1",
    "fastmcp": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
